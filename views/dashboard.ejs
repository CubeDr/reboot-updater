<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Reboot Updater</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <p class="eyebrow">CubeDr</p>
          <h1>홈페이지 zip 업로드</h1>
        </div>
        <form method="post" action="/logout">
          <button class="secondary" type="submit">로그아웃</button>
        </form>
      </header>

      <section class="panel">
        <% if (error) { %>
          <p class="alert"><%= error %></p>
        <% } %>

        <% if (result) { %>
          <div class="success">
            <strong>업로드 완료</strong>
            <span><%= result.fileCount %>개 파일, <%= result.totalBytes %> bytes</span>
            <a href="<%= result.commitUrl %>" target="_blank" rel="noreferrer">zip 브랜치 커밋 보기</a>
          </div>
        <% } %>

        <% if (restore) { %>
          <div class="success">
            <strong>복원 요청 완료</strong>
            <span>새 복원 커밋 <%= restore.shortSha %>이 main에 생성되었습니다.</span>
            <a href="<%= restore.commitUrl %>" target="_blank" rel="noreferrer">복원 커밋 보기</a>
          </div>
        <% } %>

        <form method="post" action="/upload" enctype="multipart/form-data" class="stack">
          <label>
            홈페이지 zip 파일
            <input name="homepageZip" type="file" accept=".zip,application/zip" required />
          </label>
          <button type="submit">업로드</button>
        </form>
      </section>

      <section class="panel history-panel">
        <div class="section-heading">
          <h2>최근 배포 이력</h2>
        </div>

        <% if (historyError) { %>
          <p class="alert">배포 이력을 불러오지 못했습니다. <%= historyError %></p>
        <% } else if (deployments.length === 0) { %>
          <p class="muted">아직 표시할 배포 이력이 없습니다.</p>
        <% } else { %>
          <div class="history-list">
            <% deployments.forEach((deployment, index) => { %>
              <article class="history-item">
                <div>
                  <strong><%= deployment.message %></strong>
                  <span>
                    <%= deployment.shortSha %> ·
                    <%= new Date(deployment.date).toLocaleString("ko-KR", { timeZone: "Asia/Seoul" }) %> ·
                    <%= deployment.author %>
                  </span>
                </div>
                <div class="history-actions">
                  <a href="<%= deployment.url %>" target="_blank" rel="noreferrer">보기</a>
                  <% if (index === 0) { %>
                    <span class="current-badge">현재</span>
                  <% } else { %>
                    <form
                      method="post"
                      action="/restore"
                      onsubmit="return confirm('선택한 버전으로 홈페이지를 복원할까요? 이 작업은 main 브랜치에 새 복원 커밋을 만듭니다.');"
                    >
                      <input type="hidden" name="sha" value="<%= deployment.sha %>" />
                      <button class="secondary" type="submit">이 버전으로 복원</button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="details">
        <div>
          <span>대상 저장소</span>
          <strong><%= config.githubOwner %>/<%= config.homepageRepo %></strong>
        </div>
        <div>
          <span>업로드 브랜치</span>
          <strong><%= config.zipBranch %></strong>
        </div>
        <div>
          <span>zip 경로</span>
          <strong><%= config.zipPath %></strong>
        </div>
      </section>
    </main>
  </body>
</html>
